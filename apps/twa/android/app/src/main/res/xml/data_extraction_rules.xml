<?xml version="1.0" encoding="utf-8"?>
<!--
   Regras de extração de dados para Android 12+.
   Como o app não faz backup, as regras são vazias.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
